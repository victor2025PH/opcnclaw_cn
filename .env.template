# ════════════════════════════════════════════════════
#  OpenClaw AI 语音助手 — 环境配置
#  只需填写需要修改的项，其余保持注释状态即可使用默认值
# ════════════════════════════════════════════════════

# ── 服务器端口（通常不需要修改） ──────────────────
# OPENCLAW_HOST=0.0.0.0
# OPENCLAW_PORT=8765
# OPENCLAW_HTTP_PORT=8766
# OPENCLAW_REQUIRE_AUTH=false

# ── 语音识别 STT ─────────────────────────────────
# 模型选择: tiny(最快) / base(默认) / small(较准) / medium(最准,慢)
# OPENCLAW_STT_MODEL=base
# OPENCLAW_STT_DEVICE=auto
# OPENCLAW_STT_LANGUAGE=zh

# ── 语音合成 TTS ─────────────────────────────────
# Edge TTS voice（微软免费）
# EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# ── 智谱视觉模型（可选，用于摄像头图像理解）─────
# ZHIPU_VISION_API_KEY=
# ZHIPU_VISION_MODEL=glm-4v-flash

# ── 日志配置 ─────────────────────────────────────
# OPENCLAW_LOG_LEVEL=DEBUG
# OPENCLAW_LOG_ROTATION=5 MB
# OPENCLAW_LOG_RETENTION=14 days

# ── DashScope API（阿里云语音识别/合成）──────────
# DASHSCOPE_API_KEY=

# ── 唤醒词配置 ───────────────────────────────────
# OPENCLAW_WAKE_WORDS=你好,小龙,龙虾,hey claw

# ── HomeAssistant 智能家居（可选）─────────────────
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=你的长期访问令牌

# ── OpenClaw 网关（高级，通常不需要） ─────────────
# OPENCLAW_GATEWAY_URL=
# OPENCLAW_GATEWAY_TOKEN=
