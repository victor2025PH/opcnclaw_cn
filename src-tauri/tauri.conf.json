{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "十三香小龙虾",
  "version": "4.1.0",
  "identifier": "com.shisanxiang.openclaw",
  "build": {
    "frontendDist": "../src/client",
    "devUrl": "http://localhost:8766/app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
